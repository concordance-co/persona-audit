# Copy to .env. Do not commit real values.
#
# Naming: PERSONA_AUDIT_* is the supported prefix. The older BEHAVIOR_AUDIT_*
# prefix (and XENON_NEON_DATABASE_URL for the database URL) still works as a
# deprecated alias and emits a DeprecationWarning.

PERSONA_AUDIT_DATABASE_URL=
HF_TOKEN=

# Comma-separated allowed CORS origins for shared deployments (default "*";
# credentials are only allowed when explicit origins are set).
PERSONA_AUDIT_CORS_ORIGINS=

# Optional provider/source overrides.
PERSONA_AUDIT_PROVIDER=
PERSONA_AUDIT_DEFAULT_PROVIDER=
PERSONA_AUDIT_TRACE_SOURCE=
PERSONA_AUDIT_TRACE_TABLE=
PERSONA_AUDIT_TURN_TABLE=
PERSONA_AUDIT_TAU2_PROVIDER=
PERSONA_AUDIT_TAU2_RESULTS=
PERSONA_AUDIT_HERMES_STATE_DB=
PERSONA_AUDIT_HERMES_PROVIDER=
PERSONA_AUDIT_HERMES_INCLUDE_ARCHIVED=
PERSONA_AUDIT_HERMES_DEMO_TRACES=

# Optional score overrides.
PERSONA_AUDIT_SCORE_RUN_ID=
PERSONA_AUDIT_HERMES_SCORE_RUN_ID=
PERSONA_AUDIT_DEMO_SCORE_RUN_ID=
PERSONA_AUDIT_SCORE_TABLE=
PERSONA_AUDIT_HERMES_SCORE_TABLE=
PERSONA_AUDIT_SCORE_SUMMARY_TABLE=
PERSONA_AUDIT_SCORE_SUMMARY_CACHE=

# Optional workflow input limits.
PERSONA_AUDIT_TAU2_SCORE_LIMIT=
PERSONA_AUDIT_HERMES_SCORE_LIMIT=
PERSONA_AUDIT_HERMES_SCORE_TRACE_IDS=
PERSONA_AUDIT_HERMES_INCLUDE_REASONING=

# Modal infrastructure (bring-your-own-account; see backend/scripts/bootstrap_modal.py).
# Defaults create/use persona-audit-{models,data} volumes and the "huggingface"
# secret on YOUR Modal account. The model id defaults to Llama-3.3-70B — the
# released vector spaces are precomputed against it, so changing the model
# changes the science, not just the cost.
PERSONA_AUDIT_MODEL_VOLUME=
PERSONA_AUDIT_DATA_VOLUME=
PERSONA_AUDIT_HF_SECRET=
PERSONA_AUDIT_MODEL_ID=

# Persisted high-stakes probe steps need probe artifacts on your data volume;
# default off (the dashboard's bundled high-stakes surfaces are unaffected).
PERSONA_AUDIT_ENABLE_HIGH_STAKES_PROBES=

# Optional workflow runner knobs.
PERSONA_AUDIT_TAU2_CAPTURE_GPU=
PERSONA_AUDIT_HERMES_CAPTURE_GPU=
PERSONA_AUDIT_TAU2_CAPTURE_TIMEOUT=
PERSONA_AUDIT_HERMES_CAPTURE_TIMEOUT=
PERSONA_AUDIT_TAU2_CAPTURE_MAX_CONTAINERS=
PERSONA_AUDIT_HERMES_CAPTURE_MAX_CONTAINERS=
PERSONA_AUDIT_TAU2_CAPTURE_SHARDS=
PERSONA_AUDIT_HERMES_CAPTURE_SHARDS=
PERSONA_AUDIT_TAU2_ANALYSIS_TIMEOUT=
PERSONA_AUDIT_HERMES_ANALYSIS_TIMEOUT=
PERSONA_AUDIT_TAU2_MAX_MODEL_LEN=
PERSONA_AUDIT_HERMES_MAX_MODEL_LEN=
PERSONA_AUDIT_TAU2_TENSOR_PARALLEL_SIZE=
PERSONA_AUDIT_HERMES_TENSOR_PARALLEL_SIZE=
PERSONA_AUDIT_TAU2_GPU_MEMORY_UTILIZATION=
PERSONA_AUDIT_HERMES_GPU_MEMORY_UTILIZATION=
PERSONA_AUDIT_TAU2_ENFORCE_EAGER=
PERSONA_AUDIT_HERMES_ENFORCE_EAGER=
PERSONA_AUDIT_TAU2_MAX_NUM_SEQS=
PERSONA_AUDIT_HERMES_MAX_NUM_SEQS=
PERSONA_AUDIT_TAU2_MAX_NUM_BATCHED_TOKENS=
PERSONA_AUDIT_HERMES_MAX_NUM_BATCHED_TOKENS=

# Optional override for the bundled persona-demo trace file read by the dashboard.
PERSONA_AUDIT_DEMO_PRODUCT_TRACES=

# Demo hill-climb loop (set by factory/scripts/demo_hillclimb.py; rarely set by hand).
PERSONA_AUDIT_DEMO_ROUND_FILE=
PERSONA_AUDIT_DEMO_TRACES_FILE=

# Optional demo-generation workflow knobs (factory/workflows/demo_generation.py).
PERSONA_AUDIT_DEMO_GENERATION_GPU=
PERSONA_AUDIT_DEMO_GENERATION_TIMEOUT=
PERSONA_AUDIT_DEMO_GENERATION_MAX_TOKENS=
PERSONA_AUDIT_DEMO_GENERATION_TEMPERATURE=
PERSONA_AUDIT_DEMO_GENERATION_TOP_P=
PERSONA_AUDIT_DEMO_GENERATION_MAX_MODEL_LEN=
PERSONA_AUDIT_DEMO_GENERATION_TENSOR_PARALLEL_SIZE=
PERSONA_AUDIT_DEMO_GENERATION_GPU_MEMORY_UTILIZATION=
PERSONA_AUDIT_DEMO_GENERATION_ENFORCE_EAGER=
PERSONA_AUDIT_DEMO_GENERATION_MAX_NUM_SEQS=
PERSONA_AUDIT_DEMO_GENERATION_MAX_NUM_BATCHED_TOKENS=

# Path to the local Xenon checkout for running Modal workflows from this repo.
# See docs/xenon-modal-runbook.md.
XENON_WORKSPACE_ROOT=

# Agent command the hill-climb `tick` launches on ESCALATE_PROMPT to author one
# persona prompt revision (e.g. "claude -p --model sonnet" or "codex exec").
# Unset = tick reports the escalation and exits 3 for a human to handle.
# See docs/internal/demo-monitoring-plan.md.
DEMO_HILLCLIMB_ESCALATOR_CMD=
