# Path to the local Xenon checkout for running Modal workflows from this repo.
# See docs/xenon-modal-runbook.md.
XENON_WORKSPACE_ROOT=

# Agent command the hill-climb `tick` launches on ESCALATE_PROMPT to author one
# persona prompt revision (e.g. "claude -p --model sonnet" or "codex exec").
# Unset = tick reports the escalation and exits 3 for a human to handle.
# See docs/demo-monitoring-plan.md.
DEMO_HILLCLIMB_ESCALATOR_CMD=
